# ============================================================================
# PostgreSQL Docker — Environment Configuration
#
# All variables are commented out and show their DEFAULT (the same value
# used by docker-compose.yml if left unset). Copy this file to `.env` and
# uncomment ONLY the lines you want to override.
#
#     cp .env.example .env
# ============================================================================

# ---- Image / version ----
# Tags: https://hub.docker.com/_/postgres
#
# NOTE: PG 18+ uses the new volume layout mounted at /var/lib/postgresql.
# For PG 17 or older you'd have to change the volume target in
# docker-compose.yml from /var/lib/postgresql to /var/lib/postgresql/data.
#POSTGRES_VERSION=18-alpine

# ---- Credentials / database ----
# Applied ONLY on the first boot (empty data volume). Change password BEFORE
# first start, or later with: ALTER USER postgres WITH PASSWORD '...';
#POSTGRES_USER=postgres
#POSTGRES_PASSWORD=postgres
#POSTGRES_DB=postgres

# Extra args for initdb — applied ONLY on first boot.
#POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C

# ---- Networking ----
# Host interface to publish the port on:
#   127.0.0.1 -> local only (recommended for dev)
#   0.0.0.0   -> all interfaces (LAN)
#POSTGRES_BIND_HOST=127.0.0.1
#POSTGRES_PORT=5432

# External docker network name (you create it manually — see README).
#POSTGRES_NETWORK=postgres_net

# ---- Storage ----
# External docker volume for DB data (you create it manually — see README).
#POSTGRES_DATA_VOLUME=postgres_data

# Host directory for log files (bind-mounted to /var/log/postgresql).
# Only populated if your POSTGRES_COMMAND enables logging_collector (see below).
#POSTGRES_LOGS_DIR=./logs

# ---- Runtime ----
# Shared memory (parallel queries, large sort/hash operations).
#SHM_SIZE=256mb

# Grace period before SIGKILL on stop (gives PG time to checkpoint).
#STOP_GRACE_PERIOD=1m

# ---- Time zone ----
# IANA tz name — full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples:
#   UTC
#   America/La_Paz       (Bolivia,  UTC-4)
#   America/Argentina/Buenos_Aires
#   America/Santiago     (Chile)
#   America/Lima         (Perú)
#   America/Bogota       (Colombia)
#   America/Mexico_City
#   America/Sao_Paulo    (Brasil)
#   Europe/Madrid
#TZ=UTC

# ============================================================================
# POSTGRES_COMMAND — server runtime tuning
#
# Passed verbatim to `postgres` as extra arguments. Use `-c key=value` pairs.
# Generate values with pgtune: https://pgtune.leopard.in.ua/
#
# Example (8 GB RAM / 4 cores / SSD / OLTP workload — tune to your hardware):
#
#POSTGRES_COMMAND="-c max_connections=200 -c shared_buffers=2GB -c effective_cache_size=6GB -c maintenance_work_mem=512MB -c checkpoint_completion_target=0.9 -c wal_buffers=16MB -c default_statistics_target=100 -c random_page_cost=1.1 -c effective_io_concurrency=200 -c work_mem=2621kB -c huge_pages=off -c min_wal_size=1GB -c max_wal_size=4GB -c max_worker_processes=4 -c max_parallel_workers_per_gather=2 -c max_parallel_workers=4 -c max_parallel_maintenance_workers=2"
#
# To also write logs to files under ./logs (bind-mounted), append:
#   -c logging_collector=on
#   -c log_directory=/var/log/postgresql
#   -c log_filename=postgresql-%Y-%m-%d.log
#   -c log_rotation_age=1d
#   -c log_rotation_size=0
# ============================================================================
