# ============================================================================
# PostgreSQL Docker — Environment Configuration
#
# All variables are commented out and show their DEFAULT value (the same one
# used by docker-compose.yml if left unset). Copy this file to `.env` and
# uncomment ONLY the lines you want to override.
#
#     cp .env.example .env
# ============================================================================

# ---- Compose project ----
# Groups resources under this name in `docker compose ls`.
#COMPOSE_PROJECT_NAME=postgres

# ---- Container identity ----
#CONTAINER_NAME=postgres

# ---- Image / version ----
# Tags: https://hub.docker.com/_/postgres
#POSTGRES_VERSION=18-alpine

# Data mount path INSIDE the container. Depends on PG major version:
#   PG 18+  -> /var/lib/postgresql          (new layout, per-version subdir)
#   PG <=17 -> /var/lib/postgresql/data     (legacy layout)
#POSTGRES_DATA_TARGET=/var/lib/postgresql

# ---- Credentials / database ----
# Applied ONLY on the first boot (empty data volume). Change password BEFORE
# first start, or change it later with ALTER USER inside psql.
#POSTGRES_USER=postgres
#POSTGRES_PASSWORD=postgres
#POSTGRES_DB=postgres

# Extra args for initdb — applied ONLY on first boot.
#POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C

# ---- Networking ----
# Host interface to publish the port on:
#   127.0.0.1 -> local only (recommended for dev)
#   0.0.0.0   -> all interfaces (LAN)
#POSTGRES_BIND_HOST=127.0.0.1
#POSTGRES_PORT=5432

# External docker network name (you create it manually — see README).
#POSTGRES_NETWORK=postgres_net

# ---- Storage ----
# External docker volume for DB data (you create it manually — see README).
#POSTGRES_DATA_VOLUME=postgres_data

# Host directory for log files (bind-mounted to /var/log/postgresql).
#POSTGRES_LOGS_DIR=./logs

# Path to the custom postgresql.conf (bind-mounted read-only).
#POSTGRES_CONFIG_FILE=./custom.conf

# ---- Runtime ----
# Shared memory (parallel queries, large sort/hash operations).
#SHM_SIZE=256mb

# Restart policy: no | always | on-failure | unless-stopped
#RESTART_POLICY=unless-stopped

# Grace period before SIGKILL on stop (gives PG time to checkpoint).
#STOP_GRACE_PERIOD=1m

# ---- Time zone ----
#TZ=UTC
